# ── MongoDB Atlas ──
# Get free cluster at https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/rooms?retryWrites=true&w=majority

# ── Session secret (generate a random string) ──
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# ── Gmail App Password ──
# 1. Enable 2FA on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Create an app password for "Mail"
GMAIL_USER=yourapp@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Frontend URL (Netlify URL after deploy) ──
FRONTEND_URL=https://your-rooms-app.netlify.app

# ── Server port (Render sets this automatically) ──
PORT=4000

# ── Environment ──
NODE_ENV=production
